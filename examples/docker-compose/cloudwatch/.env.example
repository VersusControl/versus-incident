# =====================================================================
# CloudWatch-Logs-source example — copy to .env and edit.
# =====================================================================
GATEWAY_SECRET=change-me
REDIS_PASSWORD=versus

SLACK_ENABLE=false
SLACK_TOKEN=
SLACK_CHANNEL_ID=

TELEGRAM_ENABLE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

AGENT_ENABLE=true
AGENT_MODE=training

AGENT_AI_ENABLE=false
AGENT_AI_API_KEY=
AGENT_AI_MODEL=gpt-4o-mini

# ---- AWS credentials -------------------------------------------------
# Either set these env vars or uncomment the ~/.aws bind in
# docker-compose.yml.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=                     # only when using STS / SSO

# ---- CloudWatch source ----------------------------------------------
CW_REGION=us-east-1
CW_LOG_GROUP_NAME=/aws/lambda/my-function
CW_LOG_STREAM_PREFIX=                  # optional, narrows scan
CW_FILTER_PATTERN=                     # optional, e.g. '?ERROR ?Exception'
