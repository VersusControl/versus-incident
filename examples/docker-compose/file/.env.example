# =====================================================================
# File-source example — copy to .env and edit.
# =====================================================================
GATEWAY_SECRET=change-me
REDIS_PASSWORD=versus

# Notification channels — flip to true and fill in to enable.
SLACK_ENABLE=false
SLACK_TOKEN=
SLACK_CHANNEL_ID=

TELEGRAM_ENABLE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI agent
AGENT_ENABLE=true
AGENT_MODE=training      # training | shadow | detect

# AI SRE (used only when AGENT_MODE=detect)
AGENT_AI_ENABLE=false
AGENT_AI_API_KEY=
AGENT_AI_MODEL=gpt-4o-mini
