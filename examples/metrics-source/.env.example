# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit a real key.
#   cp .env.example .env

# --- Enterprise license (REQUIRED) -------------------------------------------
# Offline-verified Ed25519 license JWT. It MUST carry the `intelligence`
# entitlement, or the `prometheus`/`traces` data source returns
# "requires Versus Enterprise". See the README → "License" for how to obtain
# one. Leave empty and the binary runs in community mode (no data source).
LICENSE_KEY=

# --- Enterprise image --------------------------------------------------------
# Override to pin a specific tag or use a locally-built image.
VERSUS_ENTERPRISE_IMAGE=ghcr.io/versuscontrol/versus-enterprise:dev

# --- Shared / OSS knobs (safe local defaults; override as you like) ----------
# No gateway secret: the enterprise data plane / admin UI is authenticated by a
# LIVE SESSION — the built-in default admin (password printed ONCE in the logs
# on first boot) or SSO. The compose file sets VERSUS_ENTERPRISE_COOKIE_INSECURE
# (dev-only) so that session cookie survives plain HTTP on localhost.
REDIS_PASSWORD=versus

AGENT_ENABLE=true
AGENT_MODE=detect

# --- Optional: AI analyzer (needed only to see query_metrics/query_traces) ---
AGENT_AI_ENABLE=false
AGENT_AI_API_KEY=
AGENT_AI_MODEL=gpt-4o-mini

# --- Optional: standing-intelligence layer (X16 baseline / X15 auto-SLO) -----
# Leave INTEL_SERVICES empty and the wedge is a no-op — the rule-based
# `prometheus` data source still fires incidents on its own. Set the JSON
# below to ALSO learn per-service baselines, auto-derive an availability SLO,
# and page on a multi-window burn rate. This needs a LEARNING WINDOW (the SLO
# job runs every ~5m, baselines every ~10m) — see README "Standing
# intelligence". The address defaults to the in-compose Prometheus.
INTEL_PROM_ADDRESS=http://prometheus:9090
# INTEL_SERVICES=[{"name":"checkout","signals":[{"metric":"error_rate","query":"sum(rate(demo_http_requests_total{service=\"checkout\",code=~\"5..\"}[5m]))"},{"metric":"p95_latency","query":"histogram_quantile(0.95, sum by (le) (rate(demo_http_request_duration_seconds_bucket{service=\"checkout\"}[5m])))"}],"good_query":"sum(rate(demo_http_requests_total{service=\"checkout\",code!~\"5..\"}[5m]))","total_query":"sum(rate(demo_http_requests_total{service=\"checkout\"}[5m]))"}]
INTEL_SERVICES=

# --- Optional: notifications -------------------------------------------------
SLACK_ENABLE=false
SLACK_TOKEN=
SLACK_CHANNEL_ID=
TELEGRAM_ENABLE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
