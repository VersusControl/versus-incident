# Copy to `.env` and fill in — `.env` is GITIGNORED. NEVER commit a real key.
#   cp .env.example .env
#
# These keys become the `versus-secrets` Secret (via kustomize secretGenerator).

# --- Enterprise license (required for HA enterprise features) ----------------
# Offline-verified Ed25519 JWT. Leave empty and the stack still boots in
# community mode (topology + instance identity visible), but the SSO /
# session-convergence proof needs a real key. NEVER commit it.
license_key=PASTE_YOUR_ENTERPRISE_LICENSE_JWT_HERE

# --- Postgres (LOCAL DEV DEFAULTS) -------------------------------------------
# postgres_password must match the password embedded in postgres_dsn. For
# production, use a managed Postgres (RDS) and sslmode=require.
postgres_password=versus
postgres_dsn=postgres://versus:versus@versus-postgres:5432/versus?sslmode=disable
