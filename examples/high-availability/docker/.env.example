# Copy to `.env` and fill in. `.env` is GITIGNORED — NEVER commit a real key.
#   cp .env.example .env

# --- Enterprise license (required for HA enterprise features) ----------------
# Offline-verified Ed25519 JWT. Leave empty and the stack still boots in
# community mode (topology + per-replica instance index visible); the SSO /
# session-convergence proof needs a real key. NEVER commit it.
LICENSE_KEY=

# --- Enterprise image --------------------------------------------------------
# Override to pin a tag or use a locally-built image.
VERSUS_ENTERPRISE_IMAGE=ghcr.io/versuscontrol/versus-enterprise

# --- Postgres (LOCAL DEV DEFAULTS; not real secrets) -------------------------
POSTGRES_USER=versus
POSTGRES_PASSWORD=versus
POSTGRES_DB=versus

# --- Load balancer host port -------------------------------------------------
LB_PORT=8080
